{
  "name": "@team-projects/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.23.1",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "verify:browser": "node scripts/verify-browser.mjs",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@lucide/vue": "1.24.0",
    "ant-design-vue": "4.2.6",
    "axios": "1.18.1",
    "dompurify": "3.3.0",
    "markdown-it": "14.1.0",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/markdown-it": "14.1.2",
    "@types/node": "22.20.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vue/test-utils": "2.4.11",
    "eslint": "9.39.1",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "7.3.6",
    "vitest": "4.1.10",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7"
  }
}
