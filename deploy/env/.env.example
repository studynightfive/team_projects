# ============================================================
# 鏅鸿兘鐭ヨ瘑搴撳钩鍙?- 寮€鍙戠幆澧冨彉閲忔ā鏉?# 浣跨敤鏂瑰紡锛氬鍒舵鏂囦欢涓?.env 骞跺～鍏ュ疄闄呭€?#   cp deploy/env/.env.example deploy/env/.env
# 娉ㄦ剰锛?env 鏂囦欢缁濅笉鑳芥彁浜ゅ埌 Git锛堝凡鍦?.gitignore 涓帓闄わ級
# ============================================================

# ----------------------------------------------------------
# PostgreSQL 鏁版嵁搴撳瘑鐮侊紙蹇呴渶锛?# 鐢ㄤ簬 Docker Compose 涓?postgres 鏈嶅姟鐨?POSTGRES_PASSWORD
# 浠ュ強 api-server 鍜?worker 鐨?DATABASE_URL
# ----------------------------------------------------------
POSTGRES_PASSWORD=change-me-to-a-secure-password

# ----------------------------------------------------------
# JWT 绛惧悕瀵嗛挜锛堝繀闇€锛?# 鐢ㄤ簬鐢熸垚鍜岄獙璇?JWT Token
# 鐢熶骇鐜蹇呴』浣跨敤闅忔満鐢熸垚鐨勫己瀵嗛挜锛堣嚦灏?32 瀛楃锛?# 鍙娇鐢ㄤ互涓嬪懡浠ょ敓鎴愶細openssl rand -hex 32
# ----------------------------------------------------------
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ----------------------------------------------------------
# 璋冭瘯妯″紡锛堝彲閫夛紝榛樿 false锛?# 寮€鍙戠幆澧冨彲璁句负 true锛屽惎鐢ㄨ缁嗘棩蹇楀拰鐑噸杞?# 鐢熶骇鐜蹇呴』璁句负 false
# ----------------------------------------------------------
DEBUG=false

# ----------------------------------------------------------
# DeepSeek RAG 闂瓟妯″瀷锛堟紨绀哄繀闇€锛?# API Key 鍙啓鍏ユ湰鍦?.env锛屼笉鎻愪氦浠撳簱銆?# 鍚庣灏嗕娇鐢?OpenAI 鍏煎 /chat/completions 鎺ュ彛鐢熸垚鍩轰簬寮曠敤鐨勭瓟妗堛€?# ----------------------------------------------------------
# DEEPSEEK_API_KEY=<YOUR_DEEPSEEK_API_KEY>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro

# ----------------------------------------------------------
# Qwen3 Embedding 妯″瀷锛堝悜閲忔绱㈠彲閫夛紝鎺ㄨ崘锛?# 浣跨敤闃块噷浜?DashScope OpenAI 鍏煎 /embeddings 鎺ュ彛銆?# API Key 鍙啓鍏ユ湰鍦?.env锛屼笉鎻愪氦浠撳簱銆?# ----------------------------------------------------------
# DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=qwen3.7-text-embedding
QWEN_EMBEDDING_DIMENSIONS=1024
