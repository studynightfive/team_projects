# 智能知识库平台本地开发/联调环境变量模板
# 复制为 deploy/env/.env 后填写；真实 .env 永远不要提交。

# 必填：PostgreSQL 密码与 JWT 签名密钥。数据库密码需使用 URL-safe 字符，
# 因为 Compose 会把它嵌入 DATABASE_URL；不要使用 @、:、/、?、#、[、]。
POSTGRES_PASSWORD=change-me-to-a-secure-password
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# 生产必填：分别生成稳定 Fernet 密钥和独立下载签名密钥；不要与 SECRET_KEY 复用。
# MODEL_KEY_FERNET_KEY=<YOUR_FERNET_KEY>
# EXPORT_DOWNLOAD_SIGNING_KEY=<YOUR_EXPORT_SIGNING_KEY>

# 演示数据默认关闭；仅在隔离演示环境显式开启。
# 生产环境必须保持 false。
APP_ENVIRONMENT=development
AUTO_SEED_DEMO_DATA=false
# 仅当 AUTO_SEED_DEMO_DATA=true 时必填，至少 12 位；不要提交真实值。
# DEMO_SEED_PASSWORD=<YOUR_DEMO_SEED_PASSWORD>
COOKIE_SECURE=false
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=false

# 可选：固定本地发布/回滚镜像标签；源码构建默认使用 local。
APP_IMAGE_TAG=local

# RAG 问答（OpenAI 兼容）。API Key 只写入本地 .env。
# DeepSeek 示例：DEEPSEEK_BASE_URL=https://api.deepseek.com DEEPSEEK_CHAT_MODEL=deepseek-chat
# MiniMax 示例：DEEPSEEK_BASE_URL=https://api.minimax.io/v1 DEEPSEEK_CHAT_MODEL=MiniMax-M3
# DEEPSEEK_API_KEY=<YOUR_CHAT_API_KEY>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# DashScope Embedding。API Key 只写入本地 .env。
# text-embedding-v2 固定 1536 维；v3/v4 可配 1024（需与库表 vector 维一致）。
# DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v2
QWEN_EMBEDDING_DIMENSIONS=1536

# DashScope 纯文本 Rerank，与 Embedding 复用 DASHSCOPE_API_KEY。
DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
QWEN_RERANK_MODEL=qwen3-rerank

# RAG 问答缓存（Redis）：相同用户+知识库+问题优先命中缓存
# RAG_ANSWER_CACHE_ENABLED=true
# RAG_ANSWER_CACHE_TTL_SECONDS=604800

PDF_MAX_PAGES=500
PDF_PARSE_MEMORY_LIMIT_MB=512
