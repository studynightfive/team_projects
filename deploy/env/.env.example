# ============================================================
# 智能知识库平台 - 开发环境变量模板
# 使用方式：复制此文件为 .env 并填入实际值
#   cp deploy/env/.env.example deploy/env/.env
# 注意：.env 文件绝不能提交到 Git（已在 .gitignore 中排除）
# ============================================================

# ----------------------------------------------------------
# PostgreSQL 数据库密码（必需）
# 用于 Docker Compose 中 postgres 服务的 POSTGRES_PASSWORD
# 以及 api-server 和 worker 的 DATABASE_URL
# ----------------------------------------------------------
POSTGRES_PASSWORD=change-me-to-a-secure-password

# ----------------------------------------------------------
# JWT 签名密钥（必需）
# 用于生成和验证 JWT Token
# 生产环境必须使用随机生成的强密钥（至少 32 字符）
# 可使用以下命令生成：openssl rand -hex 32
# ----------------------------------------------------------
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ----------------------------------------------------------
# 调试模式（可选，默认 false）
# 开发环境可设为 true，启用详细日志和热重载
# 生产环境必须设为 false
# ----------------------------------------------------------
DEBUG=false

# ----------------------------------------------------------
# 模型 API 密钥（可选）
# 用于调用 LLM 模型的 API 密钥
# 如果不需要 AI 问答功能，可以留空
# ----------------------------------------------------------
# MODEL_API_KEY=sk-your-api-key-here